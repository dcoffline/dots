[Unit]
Description=Persistent AI Agent Container
After=network-online.target

[Container]
Image=ai_agent:latest
Volume=/var/home/eric/src/gh/dcoffline/ai-employee/data:/app/data:Z
EnvironmentFile=%E/bash/.secrets
# Use rootless networking
Network=slirp4netns

[Install]
# Start on user login
WantedBy=default.target
