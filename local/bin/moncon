#!/bin/bash
MAIN="DP-1"
DUMMY="HDMI-A-1"

RUN=()
if [ -f /.flatpak-info ] || [ -f /run/.containerenv ]; then
  RUN=(flatpak-spawn --host --env=WAYLAND_DISPLAY="$WAYLAND_DISPLAY" --env=XAUTHORITY="$XAUTHORITY")
fi

echo "Running as $XDG_CURRENT_DESKTOP on $WAYLAND_DISPLAY" >>/tmp/sunshine_script.log

RES=${1:-1920x1080}     
REFRESH=${2:-60.000} 
SCALE=${3:-1.0}  

case "$XDG_CURRENT_DESKTOP" in
"KDE")
  "${RUN[@]}" kscreen-doctor output."$DUMMY".mode."$RES"@"${REFRESH}" output."$DUMMY".scale."$SCALE"
  ;;
"COSMIC")
  WIDTH=$(echo "$RES" | cut -d'x' -f1)
  HEIGHT=$(echo "$RES" | cut -d'x' -f2)

  "${RUN[@]}" cosmic-randr mode --refresh "$REFRESH" "$DUMMY" "$WIDTH" "$HEIGHT"
  "${RUN[@]}" cosmic-randr mode --scale "$SCALE" "$DUMMY" "$WIDTH" "$HEIGHT"
  ;;
"GNOME" | *"GNOME"*)
  GNOME_DUMMY=$(echo "$DUMMY" | sed 's/-A-/-/g')

  # Remember to verify $RES, $REFRESH, and $SCALE are actually supported by your EDID/dummy plug
  "${RUN[@]}" gdctl set -L -p -M "$GNOME_DUMMY" -m "${RES}@${REFRESH}" -s "$SCALE"
  ;;
esac
