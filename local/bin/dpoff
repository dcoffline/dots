#!/bin/bash
MAIN="DP-1"
DUMMY="DP-6"

# Dynamically detect Flatpak or Toolbx/Distrobox containers
RUN=()
if [ -f /.flatpak-info ] || [ -f /run/.containerenv ]; then
  RUN=(flatpak-spawn --host --env=WAYLAND_DISPLAY="$WAYLAND_DISPLAY" --env=XAUTHORITY="$XAUTHORITY")
fi

echo "Running as $XDG_CURRENT_DESKTOP on $WAYLAND_DISPLAY" >>"$HOME/.config/sunshine/sunshine_script.log"

case "$XDG_CURRENT_DESKTOP" in
"KDE")
  "${RUN[@]}" kscreen-doctor output."$DUMMY".enable
  sleep 1
  "${RUN[@]}" kscreen-doctor output."$MAIN".disable
  ;;
"COSMIC")
  "${RUN[@]}" cosmic-randr enable "$DUMMY"
  sleep 1
  "${RUN[@]}" cosmic-randr disable "$MAIN"
  ;;
"GNOME" | *"GNOME"*)
  GNOME_DUMMY=$(echo "$DUMMY" | sed 's/-A-/-/g')

  # 1. Wake the compositor from sleep
  "${RUN[@]}" busctl --user call org.gnome.ScreenSaver /org/gnome/ScreenSaver org.gnome.ScreenSaver SimulateUserActivity
  
  # 2. Wait for the KMS pipeline to spin up
  sleep 2
  
  # Using short flags to avoid the argparse grouping error
  "${RUN[@]}" gdctl set -L -p -M "$GNOME_DUMMY"
  "${RUN[@]}" gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled true
  "${RUN[@]}" gsettings set org.gnome.desktop.peripherals.mouse natural-scroll false
  ;;
esac
