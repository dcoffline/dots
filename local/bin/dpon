#!/bin/bash
MAIN="DP-1"
DUMMY="HDMI-A-1"

RUN=()
if [ -f /.flatpak-info ] || [ -f /run/.containerenv ]; then
  RUN=(flatpak-spawn --host --env=WAYLAND_DISPLAY="$WAYLAND_DISPLAY" --env=XAUTHORITY="$XAUTHORITY")
fi

echo "Running as $XDG_CURRENT_DESKTOP on $WAYLAND_DISPLAY" >>"$HOME/.config/sunshine/sunshine_script.log"

case "$XDG_CURRENT_DESKTOP" in
"KDE")
  "${RUN[@]}" kscreen-doctor output."$MAIN".enable output."$MAIN".mode.3440x1440@160 output."$MAIN".scale.1
  sleep 1
  "${RUN[@]}" kscreen-doctor output."$DUMMY".disable
  ;;
"COSMIC")
  "${RUN[@]}" cosmic-randr enable "$MAIN"
  "${RUN[@]}" cosmic-randr mode --refresh 160 "$MAIN" 3440 1440
  "${RUN[@]}" cosmic-randr mode --scale 1 "$MAIN" 3440 1440
  sleep 1
  "${RUN[@]}" cosmic-randr disable "$DUMMY"
  ;;
"GNOME" | *"GNOME"*)
  GNOME_MAIN=$(echo "$MAIN" | sed 's/-A-/-/g')

  "${RUN[@]}" gdctl set -L -p -M "$GNOME_MAIN"
  "${RUN[@]}" gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled false
  "${RUN[@]}" gsettings set org.gnome.desktop.peripherals.mouse natural-scroll true
  ;;
esac
