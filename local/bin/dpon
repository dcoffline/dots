#!/bin/bash

# Monitor variables ($DUMMY and $MAIN) loaded by
# ~/.config/environment.d/envvars.conf

# Log what's happening to a file for debugging
echo "Running as $XDG_CURRENT_DESKTOP on $WAYLAND_DISPLAY" >>"$HOME/.config/sunshine/sunshine_script.log"

case "$XDG_CURRENT_DESKTOP" in
"KDE")
  kscreen-doctor \
    output."$MAIN".enable \
    output."$MAIN".mode.3440x1440@160 \
    output."$MAIN".scale.1
  sleep 1
  kscreen-doctor \
    output."$DUMMY".disable
  ;;
"COSMIC")
  cosmic-randr enable "$MAIN"
  # Syntax: mode --refresh <Hz> <Output> <Width> <Height>
  cosmic-randr mode --refresh 160 "$MAIN" 3440 1440
  cosmic-randr mode --scale 1 "$MAIN" 3440 1440
  sleep 1
  cosmic-randr disable "$DUMMY"
  ;;
"GNOME" | *"GNOME"*)
  # Strip the -A- for Mutter compatibility (just in case your main monitor has one)
  GNOME_MAIN=$(echo "$MAIN" | sed 's/-A-/-/g')

  # gdctl automatically disables the DUMMY plug because it is omitted here!
  gdctl set --logical-monitor --primary --monitor "$GNOME_MAIN"
  gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled false
  gsettings set org.gnome.desktop.peripherals.mouse natural-scroll true
  ;;
esac
