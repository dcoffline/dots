#!/usr/bin/env bash
set -euo pipefail

sleep 2

# Locate rclone dynamically
if command -v rclone >/dev/null 2>&1; then
  RCLONE=$(command -v rclone)
elif [ -f "$HOME/.local/bin/rclone" ]; then
  RCLONE="$HOME/.local/bin/rclone"
elif [ -f /var/home/linuxbrew/.linuxbrew/bin/rclone ]; then
  RCLONE="/var/home/linuxbrew/.linuxbrew/bin/rclone"
elif [ -f /home/linuxbrew/.linuxbrew/bin/rclone ]; then
  RCLONE="/home/linuxbrew/.linuxbrew/bin/rclone"
else
  echo "Error: rclone binary not found. Please place the rclone binary at ~/.local/bin/rclone" >&2
  exit 1
fi
BASE_MOUNT="$HOME/.mnt/rclone"
LOGFILE="$HOME/.config/rclone/rclone-mount.log"
PID_DIR="$HOME/.config/rclone/pid"

if [ -f /run/ostree-booted ]; then
  mkdir -p /var/mnt/2T/rclone_cache
  CACHE_DIR=/var/mnt/2T/rclone_cache
  declare -A REMOTES=(
    ["alldebrid"]="AllDebrid"
    ["jotta"]="Archive"
    ["10T"]="Backup"
    ["gdrive"]="GDrive"
    ["onedrive"]="OneDrive"
    ["realdebrid"]="RealDebrid"
    ["timeline"]="Timeline"
    ["zurg"]="Zurg"
  )
else
  CACHE_DIR="$HOME/.cache/rclone_cache"
  declare -A REMOTES=(
    ["jotta"]="Archive"
    ["10T"]="Backup"
    ["gdrive"]="GDrive"
    ["onedrive"]="OneDrive"
    ["timeline"]="Timeline"
  )
fi

# Common rclone flags (edit once, applies to ALL mounts)
COMMON_FLAGS=(
  --allow-other
  --umask 002
  --dir-perms 775
  --file-perms 664
  --vfs-cache-mode writes
  --cache-dir "$CACHE_DIR"
  --vfs-read-chunk-size=64M
  --vfs-read-chunk-size-limit off
  --attr-timeout 10m
  --dir-cache-time 72h
  --vfs-cache-max-size=10G
  --vfs-cache-max-age=720h
  --vfs-cache-min-free-space=20G
  --poll-interval=1m
  --buffer-size 64M
  --log-file "$LOGFILE"
  --log-level INFO
)

# Create dirs
mkdir -p "$PID_DIR" "$BASE_MOUNT"

# Launch every mount in parallel
for remote in "${!REMOTES[@]}"; do
  target="${REMOTES[$remote]}"
  mountpoint="$BASE_MOUNT/$target"

  mkdir -p "$mountpoint"

  # Remote‑specific flags
  EXTRA_FLAGS=()
  if [[ "$remote" == "alldebrid" || "$remote" == "realdebrid" ]]; then
    EXTRA_FLAGS=(--read-only --exclude '.DS_Store' --exclude '._*')
  fi

  echo "Mounting $remote → $mountpoint"
  "$RCLONE" mount "${remote}:" "$mountpoint" "${COMMON_FLAGS[@]}" "${EXTRA_FLAGS[@]}" &

  # Save the process ID of the command we just ran
  echo $! >"$PID_DIR/${remote}.pid"
done

# Let them breathe
sleep 5

# Victory lap
echo -e "\nMount status:"
for remote in "${!REMOTES[@]}"; do
  mp="$BASE_MOUNT/${REMOTES[$remote]}"
  if mount | grep -q "$mp"; then
    echo "OK  $remote"
  else
    echo "FAIL  $remote  (check $LOGFILE)" >&2
  fi
done
